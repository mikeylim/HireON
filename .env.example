# Supabase — get from Project Settings > API Keys & Integrations > Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini — API key from https://aistudio.google.com/apikey
# Use the model ID only (for example, gemini-3.5-flash), without the "models/" prefix.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Adzuna — get from https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Jooble — get from https://jooble.org/api/about
JOOBLE_API_KEY=
