# Supabase — get from Project Settings > API Keys & Integrations > Data API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini — API key from https://aistudio.google.com/apikey
# Use model IDs only, without the "models/" prefix. Flash-Lite is well suited
# to HireON's structured extraction and scoring workload.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
# Optional: used for one retry when the primary model returns a temporary 5xx error.
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# Adzuna — get from https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Jooble — get from https://jooble.org/api/about
JOOBLE_API_KEY=
